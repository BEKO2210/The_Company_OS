# The Company OS - Backend Environment Configuration
# Copy this file to .env and fill in real values.
# The setup wizard will write this file for you on first run.

# ─── Server ──────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ─── Security ────────────────────────────────────────────────────
# Generate a strong random string for JWT_SECRET! e.g.
#   openssl rand -hex 48
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=30d
BCRYPT_ROUNDS=12
KILL_SWITCH_ARMED=true

# ─── Database ────────────────────────────────────────────────────
DATABASE_TYPE=sqlite
DATABASE_PATH=./data/company-os.db

# ─── Founder bootstrap (only used on first seed) ─────────────────
FOUNDER_EMAIL=founder@thecompany.de
FOUNDER_PASSWORD=TheCompany2025!

# ─── AI / LLM Adapter (Ollama default) ───────────────────────────
# Set OLLAMA_URL/MODEL to point the KI-Suche at a local Ollama daemon.
# Leave empty / MOCK_MODE=true to keep the in-app mock parser.
MOCK_MODE=true
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral-nemo:12b
OLLAMA_NUM_CTX=4096
OLLAMA_NUM_PREDICT=512

# ─── Other adapters (see docs/CODEOWNERS.md + wizard) ────────────
# Filled in by the setup wizard - do not commit real values here.
# EMAIL_ENABLED=false
# LINKEDIN_ENABLED=false
# BANKING_ENABLED=false
# ACCOUNTING_ENABLED=false
# GITHUB_ENABLED=false
# HOSTING_ENABLED=false
# CALENDAR_ENABLED=false
# FREELANCER_ENABLED=false

# ─── Wizard lock ─────────────────────────────────────────────────
# Set automatically by the wizard. Delete to allow re-running setup.
# SETUP_COMPLETED=true
